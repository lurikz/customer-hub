# Conexão Postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/crm

# Porta da API
PORT=3001

# CORS (separe por vírgula). * = liberar tudo (não recomendado).
CORS_ORIGIN=http://localhost:5173,http://localhost:8080

# Chave do perímetro (header x-api-key) — injetada pelo nginx
# Gere com: openssl rand -hex 32
API_KEY=troque-esta-chave-por-uma-aleatoria-bem-grande

# JWT — OBRIGATÓRIO, mínimo 32 chars
# Gere um valor forte com:  openssl rand -base64 48
JWT_SECRET=troque-este-segredo-por-uma-string-bem-grande-com-pelo-menos-32-chars
JWT_EXPIRES_IN=12h

NODE_ENV=production

# Usuário MASTER (super_admin global, sem tenant). Criado/promovido no boot.
MASTER_EMAIL=padilha.ctt@gmail.com
MASTER_PASSWORD=mp469535
MASTER_NAME=Padilha Master
