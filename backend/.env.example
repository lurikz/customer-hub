# Conexão com Postgres (no EasyPanel: postgres://user:pass@nome-do-servico-postgres:5432/db)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/crm

# Porta da API
PORT=3001

# Origens permitidas para CORS (separadas por vírgula). Use * para liberar tudo (não recomendado).
CORS_ORIGIN=http://localhost:5173,http://localhost:8080

# Chave compartilhada do perímetro (header: x-api-key) — injetada pelo nginx, não exposta ao browser
API_KEY=troque-esta-chave-por-uma-aleatoria-bem-grande

# Segredo para assinar JWT — DEVE ter pelo menos 32 chars; gere com: openssl rand -base64 48
JWT_SECRET=troque-este-segredo-por-uma-string-bem-grande-com-pelo-menos-32-chars
JWT_EXPIRES_IN=12h

# Ambiente
NODE_ENV=production

# --- MODO ABERTO TEMPORÁRIO (login desativado no frontend) ---
# Quando definidos, requisições sem JWT usam esse tenant/usuário como fallback.
# REMOVA estas variáveis quando reativar a tela de login.
DEFAULT_TENANT_ID=
DEFAULT_USER_ID=
DEFAULT_USER_EMAIL=

# --- Apenas para o seed inicial (npm run seed) ---
SEED_TENANT_NAME=Minha Empresa
SEED_USER_NAME=Admin
SEED_USER_EMAIL=admin@empresa.com
SEED_USER_PASSWORD=trocar-senha-forte
