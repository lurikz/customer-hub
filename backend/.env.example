# Conexão com Postgres (no EasyPanel: postgres://user:pass@nome-do-servico-postgres:5432/db)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/crm

# Porta da API (EasyPanel injeta automaticamente, mas defina como fallback)
PORT=3001

# Origens permitidas para CORS (separadas por vírgula). Use * para liberar tudo (não recomendado em produção)
CORS_ORIGIN=http://localhost:5173,http://localhost:8080

# Chave de API obrigatória em todas as rotas (header: x-api-key)
API_KEY=troque-esta-chave-por-uma-aleatoria-bem-grande

# Ambiente
NODE_ENV=production
